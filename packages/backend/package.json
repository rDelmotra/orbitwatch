{
  "name": "@orbitwatch/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "concurrently --kill-others-on-fail \"tsx watch src/index.ts\" \"tsx watch src/dso-worker.ts\"",
    "dso-worker": "tsx watch src/dso-worker.ts",
    "build": "tsc",
    "dso-worker:start": "node dist/dso-worker.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:golden": "tsx --test tests/dso/normalize/convert.test.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "compression": "^1.7.0",
    "cors": "^2.8.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "express-rate-limit": "^8.3.1",
    "helmet": "^8.1.0",
    "node-cron": "^3.0.0",
    "satellite.js": "^6.0.2"
  },
  "devDependencies": {
    "@types/compression": "^1.7.0",
    "@types/cors": "^2.8.0",
    "@types/express": "^4.17.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
