PORT=3001
NODE_ENV=development

# Optional: Space-Track credentials for SATCAT enrichment (active/inactive status).
# Without these the server still works — it just can't distinguish active from
# inactive payloads. Register free at https://www.space-track.org/auth/createAccount
SPACETRACK_USER=your_spacetrack_username
SPACETRACK_PASS=your_spacetrack_password

# Directory where tle-cache.json and version.json are written (relative to cwd)
CACHE_DIR=./data

# CORS — keep "*" for public deployment; restrict to your frontend domain in production
CORS_ORIGIN=*

# ── Optional: historical OMM database (time-scrubbing) ───────────────────────
# History is FULLY OPTIONAL. Leave DATABASE_URL unset and the backend behaves
# exactly as before — the /api/history/* routes return 503. Set it to a
# TimescaleDB-enabled Postgres to start accumulating daily orbital history.
# Local dev (see docker-compose.yml at the repo root): `docker compose up -d`
# DATABASE_URL=postgres://orbitwatch:orbitwatch@localhost:5432/orbitwatch
#
# TLS for managed/remote Postgres (Railway external, Timescale Cloud). Unset for
# local docker / internal-network connections.
#   require → TLS, skip cert verification (typical managed PG)
#   verify  → TLS, verify the chain
# HISTORY_DB_SSL=require
#
# Optional: where raw GP snapshots are archived (defaults to <CACHE_DIR>/history/raw).
# Point at a mounted volume to make the raw archive durable across deploys.
# HISTORY_ARCHIVE_DIR=./data/history/raw
#
# Optional: max pooled DB connections (default 8).
# HISTORY_DB_POOL_MAX=8
